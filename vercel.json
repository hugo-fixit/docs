{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "regions": ["hkg1"],
  "framework": "hugo",
  "installCommand": "pnpm install",
  "buildCommand": "chmod a+x build.sh && ./build.sh",
  "outputDirectory": "public",
  "alias": ["fixit.lruihao.cn", "hugofixit"],
  "headers": [
    {
      "source": "/sw.min.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=86400, max-age=86400"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/zh-cn/(.*)",
      "destination": "/zh-cn/404.html"
    }
  ],
  "redirects": [
    {
      "source": "/documentation/(.*)",
      "destination": "/docs/$1",
      "statusCode": 301
    },
    {
      "source": "/zh-cn/documentation/(.*)",
      "destination": "/zh-cn/docs/$1",
      "statusCode": 301
    }
  ]
}
